{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/memory-hook.sh\" preflight"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/memory-hook.sh\" recall"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "(mcp__.*__)?read_document",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/memory-hook.sh\" observe"
          }
        ]
      },
      {
        "matcher": "Bash|shell|local_shell",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/memory-hook.sh\" observe"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/memory-hook.sh\" check"
          }
        ]
      }
    ]
  }
}
